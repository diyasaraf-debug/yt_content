# Google service account credentials (required for Gemini AI generation)
# Path to your service account JSON file with Generative Language API access
GOOGLE_APPLICATION_CREDENTIALS=/Users/diyasaraf/Downloads/gso-dashboard-creds.json

# Gemini model overrides (optional — defaults shown)
GEMINI_MODEL=gemini-2.5-flash

# YouTube Data API v3 (required for video lookup + owned channel sync)
# Create at: https://console.cloud.google.com/apis/credentials
# Enable: YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-data-api-key-here

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5175,http://localhost:3000
