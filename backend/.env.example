# Copy to .env and fill in real values. .env is gitignored; .env.example is committed.

# ─── Gemini (AI metadata generation) ────────────────────────────────────────
# Path to a Google service-account JSON with the Generative Language API enabled.
# Absolute path; the file should live under backend/secrets/ (gitignored).
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/backend/secrets/service-account.json

# Optional — defaults to gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# ─── YouTube Data API v3 ────────────────────────────────────────────────────
# Used for public video metadata fetch (videos.list). Not needed for channel-owner
# writes — those use the per-channel OAuth token pasted in the UI.
# Generate at https://console.cloud.google.com/apis/credentials → Create API key
YOUTUBE_API_KEY=

# ─── App config ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5175
DATABASE_URL=sqlite:///./yt_metadata.db
