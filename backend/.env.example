# Copy to .env and fill in actual values. Never commit .env.

# YouTube Data API (public-data reads, cheaper than OAuth calls)
YOUTUBE_API_KEY=

# OAuth client (for channel owner writes — videos.update etc.)
GOOGLE_CLIENT_ID=441252924625-q53v6ob0v75dagsden1ngfjhce54ih7m.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# Service account JSON path (only needed if you actually use service-account auth,
# e.g. for BigQuery or Domain-Wide Delegation). Path is absolute.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/backend/secrets/service-account.json

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5175

# SQLite
DATABASE_URL=sqlite:///./yt_metadata.db
